{
"compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "declaration": false,
    "sourceMap": false
},

"include": ["src"],
"exclude": ["node_modules", "dist"]
}